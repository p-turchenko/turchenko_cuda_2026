	program rowl_plus_rowl_gpu
	    use cudafor
	    implicit none
	
	    integer :: l, i
	    real, allocatable :: A(:), B(:), C(:)
	    real :: t1, t2, elapsed, gflops
	
	    ! ===== Ввод =====
	    print *, "Enter vector length l:"
	    read *, l
	
	    ! ===== Выделение памяти =====
	    allocate(A(l), B(l), C(l))
	
	    ! ===== Заполнение случайными числами =====
	    call random_seed()
	    call random_number(A)
	    call random_number(B)
	
	    ! ===== Замер времени =====
	    call cpu_time(t1)
	
	    call rowl_plus_rowl_gpu_sub(A, B, C)
	
	    call cpu_time(t2)
	
	    elapsed = t2 - t1
	
	    ! ===== GFLOPS =====
	    ! 1 операция сложения на элемент
	    gflops = real(l) / (elapsed * 1.0e9)
	
	    ! ===== Запись в файл =====
	    open(unit=10, file="output.txt", status="replace")
	
	    write(10,*) "Vector A:"
	    do i = 1, l
	        write(10,*) A(i)
	    end do
	
	    write(10,*) "Vector B:"
	    do i = 1, l
	        write(10,*) B(i)
	    end do
	
	    write(10,*) "Vector C = A + B:"
	    do i = 1, l
	        write(10,*) C(i)
	    end do
|3,0,8,1,50,0,1777254871,"program rowl_plus_rowl_gpu","    use cudafor","    implicit none","","    integer :: l, i","    real, allocatable :: A(:), B(:), C(:)","    real :: t1, t2, elapsed, gflops","","    ! ===== Ввод =====","    print *, \"Enter vector length l:\"","    read *, l","","    ! ===== Выделение памяти =====","    allocate(A(l), B(l), C(l))","","    ! ===== Заполнение случайными числами =====",>24
|<"    call random_seed()","    call random_number(A)","    call random_number(B)","","    ! ===== Замер времени =====","    call cpu_time(t1)","","    call rowl_plus_rowl_gpu_sub(A, B, C)","","    call cpu_time(t2)","","    elapsed = t2 - t1","","    ! ===== GFLOPS =====","    ! 1 операция сложения на элемент","    gflops = real(l) / (elapsed * 1.0e9)","","    ! ===== Запись в файл =====",>60
|<"    open(unit=10, file=\"output.txt\", status=\"replace\")","","    write(10,*) \"Vector A:\"","    do i = 1, l","        write(10,*) A(i)","    end do","","    write(10,*) \"Vector B:\"","    do i = 1, l","        write(10,*) B(i)","    end do","","    write(10,*) \"Vector C = A + B:\"","    do i = 1, l","        write(10,*) C(i)","    end do"
"9	LINE	0
	end subroutine
|3,0,9,1,1,0,1777254634,"end subroutine"
