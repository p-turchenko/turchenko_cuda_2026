	! utils_module.f90
	module utils_module
	    implicit none
	contains
	    ! Заполнение вектора случайными числами
	    subroutine rnd_fill(a)
	        real, intent(out) :: a(:)
	        call random_number(a)
	    end subroutine rnd_fill
	
	    ! Проверка равенства двух векторов
	    function check_equal_vec(a, b, tol) result(is_equal)
	        real, intent(in) :: a(:), b(:)
	        real, intent(in), optional :: tol
	        real :: tolerance
	        logical :: is_equal
	        integer :: i
	        
	        tolerance = 1.0e-5
	        if (present(tol)) tolerance = tol
	        
	        is_equal = .true.
	        if (size(a) /= size(b)) then
	            is_equal = .false.
	            return
	        endif
	        
	        do i = 1, size(a)
	            if (abs(a(i) - b(i)) > tolerance) then
	                is_equal = .false.
	                return
	            endif
	        enddo
	    end function check_equal_vec
	end module utils_module
	
	! vec_add_cpu.f90
	module vec_add_cpu_module
	    implicit none
	contains
	    subroutine vec_add_cpu(a, b, c)
	        real, intent(in) :: a(:), b(:)
	        real, intent(out) :: c(:)
	        c = a + b
	    end subroutine vec_add_cpu
	end module vec_add_cpu_module
	
	! vec_add_module.cuf
	module vec_add_gpu_module
	    implicit none
